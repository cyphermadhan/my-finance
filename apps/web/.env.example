# --- Neon Postgres ---
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Auth.js ---
# openssl rand -base64 32
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000

# --- Google OAuth (Google Cloud Console → APIs & Services → Credentials) ---
AUTH_GOOGLE_ID=xxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxx

# --- Price proxy (from v1, optional) ---
NEXT_PUBLIC_PROXY_URL=https://my-finance-proxy.example.workers.dev
NEXT_PUBLIC_PROXY_TOKEN=change-me

# --- Invite codes ---
# openssl rand -base64 24
INVITE_CODE_SECRET=change-me
